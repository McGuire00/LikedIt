{
    "manifest_version": 3,
    "name": "LikedIt",
    "version": "1.0.1",
    "description": "Visually highlight which Instagram posts you've liked.",
    "permissions": ["tabs"],
    "host_permissions": ["https://www.instagram.com/*"],
    "content_scripts": [
        {
            "matches": ["https://www.instagram.com/*"],
            "js": ["content/injectFetchInterceptor.js"],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": ["https://www.instagram.com/*"],
            "js": ["content/content.js"],
            "css": ["content/content.css"]
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icon16_heart.png",
            "32": "assets/icon32_heart.png",
            "48": "assets/icon48.png",
            "128": "assets/icon128.png"
        }
    },
    "icons": {
        "16": "assets/icon16_heart.png",
        "32": "assets/icon32_heart.png",
        "48": "assets/icon48.png",
        "128": "assets/icon128.png"
    }
}
